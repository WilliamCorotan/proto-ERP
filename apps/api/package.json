{
  "name": "@erp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "contracts:generate": "tsx src/generate-openapi.ts",
    "contracts:types": "openapi-typescript ../../docs/openapi.json -o ../../packages/sdk/src/openapi-types.ts",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src --max-warnings=0",
    "start": "node dist/apps/api/src/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@erp/accounting": "workspace:*",
    "@erp/commerce": "workspace:*",
    "@erp/core": "workspace:*",
    "@erp/db": "workspace:*",
    "@erp/hr": "workspace:*",
    "@erp/integration": "workspace:*",
    "@erp/inventory": "workspace:*",
    "@erp/manufacturing": "workspace:*",
    "@erp/operations": "workspace:*",
    "@erp/platform-workflow": "workspace:*",
    "@erp/procurement": "workspace:*",
    "@erp/quality": "workspace:*",
    "@erp/reporting": "workspace:*",
    "@erp/sales": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/swagger-ui-express": "^4.1.8",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.9"
  }
}
