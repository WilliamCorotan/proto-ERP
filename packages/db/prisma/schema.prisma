generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  draft
  submitted
  approved
  cancelled
  closed
}

enum CustomerStatus {
  active
  paused
}

enum InvoiceStatus {
  draft
  posted
  paid
  void
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum NormalBalance {
  debit
  credit
}

enum JournalStatus {
  draft
  posted
  void
}

enum FiscalPeriodStatus {
  open
  closed
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                   User[]
  roles                   Role[]
  customers               Customer[]
  products                Product[]
  quotes                  Quote[]
  orders                  SalesOrder[]
  invoices                Invoice[]
  stockMoves              StockMovement[]
  auditEvents             AuditEvent[]
  settings                Setting[]
  customFields            CustomFieldDefinition[]
  views                   ViewDefinition[]
  automationRules         AutomationRule[]
  workflowAssignmentRules WorkflowAssignmentRule[]
  workflowEscalationRules WorkflowEscalationRule[]
  accounts                Account[]
  fiscalPeriods           FiscalPeriod[]
  taxRates                TaxRate[]
  journalEntries          JournalEntry[]
  payments                Payment[]
  bankAccounts            BankAccount[]
  bankTransactions        BankTransaction[]
  bankReconciliations     BankReconciliation[]
  periodCloses            PeriodClose[]
  landedCostAllocations   LandedCostAllocation[]
  fixedAssets             FixedAsset[]
  depreciationRuns        DepreciationRun[]
  exchangeRates           ExchangeRate[]
  commerceChannels        CommerceChannel[]
  priceLists              PriceList[]
  posProfiles             PosProfile[]
  posRegisters            PosRegister[]
  posShifts               PosShift[]
  posSales                PosSale[]
  channelCatalogItems     ChannelCatalogItem[]
  channelOrders           ChannelOrder[]
  suppliers               Supplier[]
  materialRequests        MaterialRequest[]
  rfqs                    RequestForQuote[]
  supplierQuotations      SupplierQuotation[]
  purchaseOrders          PurchaseOrder[]
  purchaseReceipts        PurchaseReceipt[]
  purchaseInvoices        PurchaseInvoice[]
  supplierPayments        SupplierPayment[]
  warehouses              Warehouse[]
  inventoryBins           InventoryBin[]
  stockLedgerEntries      StockLedgerEntry[]
  stockReservations       StockReservation[]
  stockTransfers          StockTransfer[]
  cycleCounts             CycleCount[]
  reorderPoints           ReorderPoint[]
  valuationLayers         ValuationLayer[]
  pickLists               PickList[]
  pickTasks               PickTask[]
  packRecords             PackRecord[]
  shipments               Shipment[]
  putAwayTasks            PutAwayTask[]
  barcodeScans            BarcodeScan[]
  boms                    BillOfMaterial[]
  workCenters             WorkCenter[]
  routings                Routing[]
  workOrders              WorkOrder[]
  jobCards                JobCard[]
  downtimeEntries         DowntimeEntry[]
  productionPlans         ProductionPlan[]
  mrpSuggestions          MrpSuggestion[]
  traceRecords            TraceRecord[]
  traceMovements          TraceMovement[]
  priceListItems          PriceListItem[]
  inspectionTemplates     InspectionTemplate[]
  qualityInspections      QualityInspection[]
  nonConformances         NonConformance[]
  correctiveActions       CorrectiveAction[]
  supplierScorecards      SupplierScorecard[]
  recalls                 Recall[]
  savedReports            SavedReport[]
  reportRuns              ReportRun[]
  printFormats            PrintFormat[]
  exportJobs              ExportJob[]
  dashboardDefinitions    DashboardDefinition[]
  scheduledDeliveries     ScheduledDelivery[]
  apiKeys                 ApiKeyRecord[]
  webhookSubscriptions    WebhookSubscription[]
  webhookDeliveries       WebhookDelivery[]
  deadLetterRecords       DeadLetterRecord[]
  outboxEvents            OutboxEvent[]
  workflowTasks           WorkflowTaskRecord[]
  workflowTaskOperations  WorkflowTaskOperation[]
  workflowInstances       WorkflowInstance[]
  workflowTransitions     WorkflowTransition[]
  integrationMappings     IntegrationMapping[]
  connectors              Connector[]
  leads                   Lead[]
  opportunities           Opportunity[]
  projects                ProjectRecord[]
  projectTasks            ProjectTask[]
  employees               EmployeeRecord[]
  leaveRequests           LeaveRequest[]
  departments             Department[]
  workShifts              WorkShift[]
  attendanceRecords       AttendanceRecord[]
  expenseClaims           ExpenseClaim[]
  employeeAdvances        EmployeeAdvance[]
  salaryStructures        SalaryStructure[]
  payrollRuns             PayrollRun[]
  payslips                Payslip[]
  serviceCases            ServiceCase[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles  UserRole[]

  @@unique([tenantId, email])
  @@unique([tenantId, id], map: "User_tenantId_id_key")
  @@index([tenantId])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  key         String
  name        String
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  UserRole[]

  @@unique([tenantId, key])
  @@unique([tenantId, id], map: "Role_tenantId_id_key")
}

model UserRole {
  tenantId String
  userId   String
  roleId   String

  user User @relation(fields: [tenantId, userId], references: [tenantId, id], onDelete: Cascade, onUpdate: Restrict, map: "UserRole_tenantId_userId_fkey")
  role Role @relation(fields: [tenantId, roleId], references: [tenantId, id], onDelete: Cascade, onUpdate: Restrict, map: "UserRole_tenantId_roleId_fkey")

  @@id([userId, roleId])
  @@index([tenantId, userId], map: "UserRole_tenantId_userId_idx")
  @@index([tenantId, roleId], map: "UserRole_tenantId_roleId_idx")
}

model Setting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String
  entity    String
  entityId  String
  action    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entity, entityId])
}

model WorkflowInstance {
  id         String   @id @default(cuid())
  tenantId   String
  workflowId String
  entity     String
  documentId String
  state      String
  startedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transitions WorkflowTransition[]

  @@unique([tenantId, workflowId, entity, documentId])
  @@index([tenantId, workflowId, state])
  @@index([tenantId, entity, documentId])
}

model WorkflowTransition {
  id                 String   @id
  tenantId           String
  workflowInstanceId String
  workflowId         String
  entity             String
  documentId         String
  actorId            String
  fromState          String
  toState            String
  reason             String?
  occurredAt         DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([tenantId, workflowId, occurredAt])
  @@index([tenantId, entity, documentId, occurredAt])
}

model Customer {
  id          String         @id @default(cuid())
  tenantId    String
  code        String
  name        String
  status      CustomerStatus @default(active)
  owner       String
  email       String
  creditLimit Decimal        @db.Decimal(18, 2)
  currency    String         @default("USD")
  customData  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotes        Quote[]
  posSales      PosSale[]
  channelOrders ChannelOrder[]

  @@unique([tenantId, code])
  @@unique([tenantId, id], map: "Customer_tenantId_id_key")
  @@index([tenantId, name])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  category    String
  price       Decimal  @db.Decimal(18, 2)
  currency    String   @default("USD")
  stockOnHand Int      @default(0)
  customData  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockMovements      StockMovement[]
  purchaseReceipts    PurchaseReceipt[]
  stockLedgerEntries  StockLedgerEntry[]
  stockReservations   StockReservation[]
  stockTransfers      StockTransfer[]
  cycleCounts         CycleCount[]
  reorderPoints       ReorderPoint[]
  valuationLayers     ValuationLayer[]
  pickTasks           PickTask[]
  putAwayTasks        PutAwayTask[]
  boms                BillOfMaterial[]
  routings            Routing[]
  workOrders          WorkOrder[]
  mrpSuggestions      MrpSuggestion[]
  traceRecords        TraceRecord[]
  traceMovements      TraceMovement[]
  priceListItems      PriceListItem[]
  channelCatalogItems ChannelCatalogItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
}

model Quote {
  id         String       @id @default(cuid())
  tenantId   String
  customerId String
  number     String
  status     RecordStatus @default(draft)
  validUntil DateTime
  total      Decimal      @db.Decimal(18, 2)
  currency   String       @default("USD")
  lines      Json
  customData Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict, onUpdate: Restrict, map: "Quote_tenantId_customerId_fkey")
  orders   SalesOrder[]

  @@unique([tenantId, number])
  @@unique([tenantId, id], map: "Quote_tenantId_id_key")
  @@index([tenantId, customerId], map: "Quote_tenantId_customerId_idx")
  @@index([tenantId, status])
}

model SalesOrder {
  id           String       @id @default(cuid())
  tenantId     String
  quoteId      String
  number       String
  status       RecordStatus @default(draft)
  promisedDate DateTime
  total        Decimal      @db.Decimal(18, 2)
  currency     String       @default("USD")
  customData   Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote          Quote           @relation(fields: [tenantId, quoteId], references: [tenantId, id], onDelete: Restrict, onUpdate: Restrict, map: "SalesOrder_tenantId_quoteId_fkey")
  invoices       Invoice[]
  stockMovements StockMovement[]
  pickLists      PickList[]
  posSales       PosSale[]
  channelOrders  ChannelOrder[]

  @@unique([tenantId, number])
  @@unique([tenantId, id], map: "SalesOrder_tenantId_id_key")
  @@index([tenantId, quoteId], map: "SalesOrder_tenantId_quoteId_idx")
  @@index([tenantId, status])
}

model Invoice {
  id         String        @id @default(cuid())
  tenantId   String
  orderId    String
  number     String
  status     InvoiceStatus @default(draft)
  dueDate    DateTime
  total      Decimal       @db.Decimal(18, 2)
  currency   String        @default("USD")
  customData Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order    SalesOrder @relation(fields: [tenantId, orderId], references: [tenantId, id], onDelete: Restrict, onUpdate: Restrict, map: "Invoice_tenantId_orderId_fkey")
  payments Payment[]
  posSales PosSale[]

  @@unique([tenantId, number])
  @@unique([tenantId, id], map: "Invoice_tenantId_id_key")
  @@index([tenantId, orderId], map: "Invoice_tenantId_orderId_idx")
  @@index([tenantId, status])
}

model Account {
  id            String        @id @default(cuid())
  tenantId      String
  code          String
  name          String
  type          AccountType
  normalBalance NormalBalance
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  JournalLine[]

  @@unique([tenantId, code])
  @@unique([tenantId, id], map: "Account_tenantId_id_key")
  @@index([tenantId, type])
}

model FiscalPeriod {
  id        String             @id @default(cuid())
  tenantId  String
  name      String
  startDate DateTime
  endDate   DateTime
  status    FiscalPeriodStatus @default(open)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodCloses PeriodClose[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
}

model TaxRate {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  rate      Decimal  @db.Decimal(8, 5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model JournalEntry {
  id           String        @id @default(cuid())
  tenantId     String
  number       String
  sourceEntity String?
  sourceId     String?
  memo         String
  status       JournalStatus @default(draft)
  postedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines            JournalLine[]
  payments         Payment[]
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]
  periodCloses     PeriodClose[]
  depreciationRuns DepreciationRun[]

  @@unique([tenantId, number])
  @@unique([tenantId, sourceEntity, sourceId])
  @@unique([tenantId, id], map: "JournalEntry_tenantId_id_key")
  @@index([tenantId, status])
}

model JournalLine {
  id          String   @id @default(cuid())
  tenantId    String
  entryId     String
  accountId   String
  description String
  debit       Decimal  @default(0) @db.Decimal(18, 2)
  credit      Decimal  @default(0) @db.Decimal(18, 2)
  createdAt   DateTime @default(now())

  entry   JournalEntry @relation(fields: [tenantId, entryId], references: [tenantId, id], onDelete: Cascade, onUpdate: Restrict, map: "JournalLine_tenantId_entryId_fkey")
  account Account      @relation(fields: [tenantId, accountId], references: [tenantId, id], onDelete: Restrict, onUpdate: Restrict, map: "JournalLine_tenantId_accountId_fkey")

  @@index([accountId])
  @@index([tenantId, entryId], map: "JournalLine_tenantId_entryId_idx")
  @@index([tenantId, accountId], map: "JournalLine_tenantId_accountId_idx")
}

model Payment {
  id             String   @id @default(cuid())
  tenantId       String
  invoiceId      String
  journalEntryId String?
  amount         Decimal  @db.Decimal(18, 2)
  currency       String   @default("USD")
  method         String
  receivedAt     DateTime
  createdAt      DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice      Invoice       @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onDelete: Restrict, onUpdate: Restrict, map: "Payment_tenantId_invoiceId_fkey")
  journalEntry JournalEntry? @relation(fields: [tenantId, journalEntryId], references: [tenantId, id], onDelete: SetNull, onUpdate: Restrict, map: "Payment_tenantId_journalEntryId_fkey")
  posSales     PosSale[]

  @@index([tenantId, invoiceId])
  @@index([tenantId, journalEntryId], map: "Payment_tenantId_journalEntryId_idx")
}

model BankAccount {
  id               String    @id @default(cuid())
  tenantId         String
  code             String
  name             String
  currency         String    @default("USD")
  openingBalance   Decimal   @default(0) @db.Decimal(18, 2)
  lastReconciledAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions    BankTransaction[]
  reconciliations BankReconciliation[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model BankTransaction {
  id              String    @id @default(cuid())
  tenantId        String
  bankAccountId   String
  reference       String
  direction       String
  amount          Decimal   @db.Decimal(18, 2)
  currency        String    @default("USD")
  transactionDate DateTime
  matchedEntity   String?
  matchedEntityId String?
  reconciledAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)

  @@unique([tenantId, reference])
  @@index([tenantId, bankAccountId])
  @@index([tenantId, reconciledAt])
}

model BankReconciliation {
  id               String   @id @default(cuid())
  tenantId         String
  bankAccountId    String
  statementDate    DateTime
  statementBalance Decimal  @db.Decimal(18, 2)
  currency         String   @default("USD")
  clearedBalance   Decimal  @db.Decimal(18, 2)
  variance         Decimal  @db.Decimal(18, 2)
  status           String   @default("variance")
  transactionIds   Json
  reconciledAt     DateTime @default(now())
  createdAt        DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)

  @@index([tenantId, bankAccountId])
  @@index([tenantId, status])
}

model PeriodClose {
  id             String   @id @default(cuid())
  tenantId       String
  fiscalPeriodId String
  journalEntryId String?
  status         String   @default("closed")
  closedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@unique([tenantId, fiscalPeriodId])
  @@index([tenantId, status])
}

model LandedCostAllocation {
  id                String   @id @default(cuid())
  tenantId          String
  purchaseReceiptId String
  amount            Decimal  @db.Decimal(18, 2)
  currency          String   @default("USD")
  method            String   @default("quantity")
  lines             Json
  allocatedAt       DateTime @default(now())
  createdAt         DateTime @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseReceipt PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Restrict)

  @@index([tenantId, purchaseReceiptId])
}

model FixedAsset {
  id                      String   @id @default(cuid())
  tenantId                String
  assetTag                String
  name                    String
  purchaseDate            DateTime
  cost                    Decimal  @db.Decimal(18, 2)
  currency                String   @default("USD")
  usefulLifeMonths        Int
  accumulatedDepreciation Decimal  @default(0) @db.Decimal(18, 2)
  status                  String   @default("active")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depreciationRuns DepreciationRun[]

  @@unique([tenantId, assetTag])
  @@index([tenantId, status])
}

model DepreciationRun {
  id             String   @id @default(cuid())
  tenantId       String
  fixedAssetId   String
  journalEntryId String?
  amount         Decimal  @db.Decimal(18, 2)
  currency       String   @default("USD")
  runDate        DateTime
  createdAt      DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fixedAsset   FixedAsset    @relation(fields: [fixedAssetId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@unique([tenantId, fixedAssetId, runDate])
  @@index([tenantId, fixedAssetId])
}

model ExchangeRate {
  id            String   @id @default(cuid())
  tenantId      String
  baseCurrency  String
  quoteCurrency String
  rate          Decimal  @db.Decimal(18, 8)
  effectiveDate DateTime
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, baseCurrency, quoteCurrency, effectiveDate])
  @@index([tenantId, effectiveDate])
}

model CommerceChannel {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  channelType String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  priceLists    PriceList[]
  catalogItems  ChannelCatalogItem[]
  channelOrders ChannelOrder[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model PriceList {
  id        String   @id @default(cuid())
  tenantId  String
  channelId String?
  name      String
  currency  String   @default("USD")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel     CommerceChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  items       PriceListItem[]
  posProfiles PosProfile[]

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model PriceListItem {
  id          String   @id @default(cuid())
  tenantId    String
  priceListId String
  productId   String
  price       Decimal  @db.Decimal(18, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([tenantId, priceListId, productId])
  @@index([tenantId, productId])
}

model PosProfile {
  id              String   @id @default(cuid())
  tenantId        String
  priceListId     String
  name            String
  warehouseCode   String
  cashAccountCode String   @default("1000")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  priceList PriceList     @relation(fields: [priceListId], references: [id], onDelete: Restrict)
  registers PosRegister[]

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model PosRegister {
  id        String   @id @default(cuid())
  tenantId  String
  profileId String
  code      String
  name      String
  status    String   @default("closed")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile PosProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  shifts  PosShift[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model PosShift {
  id           String    @id @default(cuid())
  tenantId     String
  registerId   String
  openedBy     String
  status       String    @default("open")
  openingCash  Decimal   @db.Decimal(18, 2)
  closingCash  Decimal?  @db.Decimal(18, 2)
  expectedCash Decimal   @default(0) @db.Decimal(18, 2)
  currency     String    @default("USD")
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  register PosRegister @relation(fields: [registerId], references: [id], onDelete: Restrict)
  sales    PosSale[]

  @@index([tenantId, status])
  @@index([tenantId, registerId])
}

